# Example environment variables for this project.
# Copy this file to .env and replace the REPLACE_ME values with real secrets.

# Database connection (Postgres/MySQL/SQLite/etc.)
DATABASE_URL="REPLACE_ME"

# Frontend Vite API key (exposed to client if prefixed with VITE_)
VITE_API_KEY=REPLACE_ME

# Optional common vars
PORT=3000
JWT_SECRET=REPLACE_ME
SMTP_HOST=REPLACE_ME
SMTP_PORT=587
SMTP_USER=REPLACE_ME
SMTP_PASS=REPLACE_ME
